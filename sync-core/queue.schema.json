{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/andreclemente/tivimate-trakt-patch/sync-core/queue.schema.json",
  "title": "TiviMate Trakt Sync Queue Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "queue_id",
    "status",
    "attempt_count",
    "next_attempt_at_ms",
    "created_at_ms",
    "updated_at_ms",
    "event"
  ],
  "properties": {
    "queue_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["pending", "in_flight", "succeeded", "failed", "dead"]
    },
    "attempt_count": { "type": "integer", "minimum": 0 },
    "next_attempt_at_ms": { "type": "integer", "minimum": 0 },
    "created_at_ms": { "type": "integer", "minimum": 0 },
    "updated_at_ms": { "type": "integer", "minimum": 0 },
    "event": { "$ref": "./events.schema.json" },
    "last_error": { "type": ["string", "null"] },
    "last_http_status": { "type": ["integer", "null"], "minimum": 100, "maximum": 599 },
    "trakt_response": { "type": ["object", "null"] }
  }
}
