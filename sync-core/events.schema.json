{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/andreclemente/tivimate-trakt-patch/sync-core/events.schema.json",
  "title": "TiviMate Trakt Sync Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "media_type",
    "timestamp_ms",
    "source"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": {
      "type": "string",
      "enum": ["start", "progress", "pause", "stop", "watched", "unwatched"]
    },
    "media_type": {
      "type": "string",
      "enum": ["movie", "episode"]
    },
    "timestamp_ms": { "type": "integer", "minimum": 0 },
    "position_ms": { "type": ["integer", "null"], "minimum": 0 },
    "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
    "progress_percent": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "title": { "type": ["string", "null"] },
    "show_title": { "type": ["string", "null"] },
    "year": { "type": ["integer", "null"], "minimum": 1800, "maximum": 3000 },
    "season": { "type": ["integer", "null"], "minimum": 0 },
    "episode": { "type": ["integer", "null"], "minimum": 0 },
    "provider_item_id": { "type": ["string", "null"] },
    "provider_playlist_id": { "type": ["string", "null"] },
    "ids": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trakt": { "type": ["integer", "null"] },
        "tmdb": { "type": ["integer", "null"] },
        "tvdb": { "type": ["integer", "null"] },
        "imdb": { "type": ["string", "null"] }
      }
    },
    "source": { "type": "string", "minLength": 1 },
    "raw_hook": {
      "type": ["object", "null"],
      "description": "Optional non-secret hook metadata for debugging. Must not include stream URLs or credentials."
    }
  }
}
